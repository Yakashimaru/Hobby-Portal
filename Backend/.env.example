# Database connection
DATABASE_HOST=your-db-host.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.your-project-id
DATABASE_PASSWORD=your-supabase-db-password

# API base URL
BASE_URL_VN=http://localhost:5004

# Cloudflare R2 / AWS S3 storage
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
BUCKET=your-bucket-name
